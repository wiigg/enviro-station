PORT=8080
CORS_ALLOW_ORIGIN=http://localhost:5173
INGEST_API_KEY=dev-ingest-key
PG_MAX_CONNS=10
DATABASE_URL=postgres://envirostation:envirostation@localhost:5432/envirostation?sslmode=disable
OPS_DEVICE_OFFLINE_TIMEOUT=45s
OPS_MONITOR_INTERVAL=5s
DATABASE_RECONNECT_INTERVAL=30s
TRUST_PROXY_HEADERS=false
LIVE_BUFFER_LIMIT=3600
OPENAI_API_KEY=
OPENAI_INSIGHTS_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_INSIGHTS_MAX=3
OPENAI_INSIGHTS_ANALYSIS_LIMIT=900
OPENAI_INSIGHTS_REFRESH_INTERVAL=1h
OPENAI_INSIGHTS_EVENT_MIN_INTERVAL=10m
OPENAI_INSIGHTS_PM2_TRIGGER=8
OPENAI_INSIGHTS_PM10_TRIGGER=30
OPENAI_INSIGHTS_PM2_DELTA_TRIGGER=5
OPENAI_INSIGHTS_PM10_DELTA_TRIGGER=15
OPENAI_INSIGHTS_HUMIDITY_LOW_TRIGGER=40
OPENAI_INSIGHTS_HUMIDITY_HIGH_TRIGGER=60
OPENAI_INSIGHTS_HUMIDITY_DELTA_TRIGGER=8
OPENAI_INSIGHTS_TEMPERATURE_LOW_TRIGGER=18
OPENAI_INSIGHTS_TEMPERATURE_HIGH_TRIGGER=26
OPENAI_INSIGHTS_TEMPERATURE_DELTA_TRIGGER=1.5
OPENAI_INSIGHTS_ANALYZE_TIMEOUT=15s
RETENTION_ENABLED=true
RETENTION_DAYS=14
RETENTION_BATCH_SIZE=5000
RETENTION_INTERVAL=24h
